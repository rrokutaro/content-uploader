# ════════════════════════════════════════════════════════════
# on-start.env.example
#
# Copy this file to on-start.env and fill in your values.
# Used by start-uploader.sh for local/Colab runs only.
# For GitHub Actions, use repository secrets instead.
#
# ⚠️  Never commit on-start.env — add it to .gitignore
# ════════════════════════════════════════════════════════════

# ── MongoDB Atlas connection string (required for state persistence) ───────
# Get this from: Atlas → Connect → Drivers → copy connection string
# Replace <db_password> with your actual password
MONGODB_URI=mongodb+srv://rrokutaro:<db_password>@uploader-cluster.xxxxx.mongodb.net/?appName=uploader-cluster

# ── GDrive folder IDs ──────────────────────────────────────────────────────
# Found in the GDrive folder URL:
# https://drive.google.com/drive/folders/<THIS_PART_HERE>
# All three folders must be shared as "Anyone with the link" (Viewer)
GDRIVE_SERVER_CONFIGS_ID=1aBcDeFgHiJkLmNoPqRsTuVwXyZ
GDRIVE_CLIENT_SECRETS_ID=1aBcDeFgHiJkLmNoPqRsTuVwXyZ
GDRIVE_CLIENT_TOKENS_ID=1aBcDeFgHiJkLmNoPqRsTuVwXyZ

# ── Which server configs to process (REQUIRED) ────────────────────────────
# Comma-separated filenames from assets/server-configs/
# e.g. one config:   UPLOADER_CONFIGS=movie-recaps.json
# e.g. multi config: UPLOADER_CONFIGS=movie-recaps.json,shorts.json
UPLOADER_CONFIGS=movie-recaps.json

# ── Min time between uploads in milliseconds ──────────────────────────────
# 900000  =  15 min
# 1800000 =  30 min  ← recommended
# 3600000 =  60 min
UPLOADER_MIN_GAP=1800000

# ── UTC upload window ──────────────────────────────────────────────────────
# Only upload during this time range (UTC). Leave empty to allow anytime.
# Format: HH:MM-HH:MM
# Examples:
#   13:00-23:00  →  targets US daytime hours
#   22:00-06:00  →  spans midnight (supported)
UPLOADER_WINDOW=13:00-23:00

# ── Dry run mode ───────────────────────────────────────────────────────────
# true  → simulates everything, no real uploads or deletes (use for testing)
# false → real uploads
UPLOADER_DRY_RUN=false

# ── Log file path ──────────────────────────────────────────────────────────
# Defaults to uploader-server.log in the same directory as start-uploader.sh
# UPLOADER_LOG_FILE=/path/to/uploader-server.log

# ── How often to re-fetch configs/secrets/tokens from GDrive (seconds) ────
# Default: 600 (10 minutes). Set to 0 to always re-fetch on every run.
UPLOADER_REFETCH_INTERVAL=600

# ── Loop mode (Colab/local only) ───────────────────────────────────────────
# true  → auto-restart after each run (keep alive)
# false → run once and exit
UPLOADER_LOOP=true

# ── Skip individual GDrive re-fetches (optional) ──────────────────────────
# Useful if you're managing asset folders manually and don't want them overwritten
# DISABLE_SERVER_CONFIGS_FETCH=true
# DISABLE_CLIENT_SECRETS_FETCH=true
# DISABLE_CLIENT_TOKENS_FETCH=true
